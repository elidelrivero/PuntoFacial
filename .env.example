# Copia este archivo como ".env" y completa tus valores reales.
# El archivo ".env" NUNCA debe subirse al repositorio (ya está en .gitignore).

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=sistema_asistencia

# Contraseña administrativa requerida para dar de baja a un empleado
ADMIN_PASSWORD=Abd6S

# Modo debug de Flask. Déjalo en False salvo que estés desarrollando en tu
# propia máquina — activado, permite ejecución remota de código si el
# servidor queda accesible desde la red.
FLASK_DEBUG=False
